---
import "../styles/global.css";

import slugify from "slugify-ts";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

import DarkMode from "../components/DarkMode.astro";

const notionContents = await getCollection("notionContent");

const projects = notionContents.map((notionContent) => {
  return {
    ...notionContent.data,
  };
});
---

<!doctype html>
<html lang="en" class="bg-white dark:bg-black dark:text-white antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Bureau Duplex</title>
  </head>
  <body>
    <div
      class="h-screen flex flex-col p-5"
      x-data="{index: false, about: false}"
    >
      <header>
        <ul
          class="grid grid-cols-[minmax(0,1fr)_50px] md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_50px] uppercase text-sm mb-3"
        >
          <li>
            <a href="/" class="uppercase">Bureau Duplex</a>
          </li>
          <li>
            <button
              x-on:click="index = !index; about = false"
              class="uppercase cursor-pointer">Index</button
            >
          </li>
          <li>
            <button
              x-on:click="about = !about; index = false"
              class="uppercase cursor-pointer">About</button
            >
          </li>
          <li class="text-right">
            <DarkMode />
          </li>
        </ul>
      </header>
      <slot name="before-content" />
      <div class="grow relative">
        <ul
          class="w-full absolute top-16 md:top-32 right-0 left-0 bg-white dark:bg-black z-9999 pb-10"
          x-show="index"
          x-cloak
        >
          {
            projects.map((project) => (
              <li x-data="{image: false}">
                <a
                  class="grid grid-cols-[minmax(0,1fr)_50px] md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_50px] text-lg md:text-sm relative z-50"
                  href={`/projects/${slugify(project.properties.project)}`}
                  @mouseover="image = true"
                  @mouseout="image = false"
                >
                  <span>{project.properties.client}</span>
                  <span class="hidden md:inline">
                    {project.properties.project}
                  </span>
                  <span class="hidden md:inline">
                    {project.properties.tags}
                  </span>
                  <span class="text-right">{project.properties.year}</span>
                </a>
                {project.cover && project.cover.type === "file" && (
                  <div
                    class="hidden md:block absolute -top-16 z-10"
                    x-show="image"
                    x-cloak
                    x-transition:enter="transition duration-300"
                    x-transition:enter-start="opacity-0 transform -translate-x-10"
                    x-transition:enter-end="opacity-100 transform translate-x-0"
                    x-transition:leave="transition duration-300"
                    x-transition:leave-start="opacity-100 transform translate-x-0"
                    x-transition:leave-end="opacity-0 transform translate-x-10"
                  >
                    <Image
                      class="max-w-1/2 mx-auto"
                      src={project.cover.file.url}
                      height={100}
                      width={100}
                      alt=""
                    />
                  </div>
                )}
              </li>
            ))
          }
        </ul>
        <div
          class="w-full absolute top-16 md:top-32 right-0 left-0 bg-white dark:bg-black z-9999 pb-10"
          x-show="about"
          x-cloak
        >
          <p class="text-lg md:text-sm max-w-[640px] mb-4">
            Fondé en 2013, BUREAUDUPLEX est un studio de création alliant
            direction artistique, design graphique, deisgn éditorial,
            illustration et motion design. Cette approche pluridisciplinaire lui
            permet de concevoir des outils narratifs adaptés à chaque projet,
            dans les champs culturels et commerciaux.
          </p>
          <p class="text-lg md:text-sm">
            Parc du Loup 1a <br />
            1018 Lausanne <br />
            CH – Switzetland <br />
            info@bureau-duplex.ch <br />
            +41 78 665 01 50
          </p>
        </div>
        <slot />
      </div>
      <slot name="after-content" />
    </div>
  </body>
</html>
