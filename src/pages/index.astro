---
import Layout from "../layouts/Layout.astro";
import slugify from "slugify-ts";
import DesktopLogo from "../components/DesktopLogo.astro";
import MobileLogoTop from "../components/MobileLogoTop.astro";
import MobileLogoBottom from "../components/MobileLogoBottom.astro";

import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const notionContents = await getCollection("notionContent");

const projects = notionContents.map((notionContent) => notionContent.data);
---

<Layout>
  <div class="md:hidden" slot="before-content">
    <MobileLogoTop />
  </div>
  <div
    class="h-full flex-col items-end hidden md:flex"
    x-data="{showed: 'none'}"
  >
    <div class="w-full grow relative">
      {
        projects.map((project, index) => (
          <div
            class="absolute inset-0 z-30"
            x-show={`showed === 'project${index}'`}
            x-cloak
          >
            <div class="h-full py-32 grid grid-cols-1 content-stretch">
              {[0, 1, 2].map((_) => (
                <div
                  class="grid grid-cols-[minmax(0,1fr)_auto] md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_auto] text-lg md:text-sm relative z-20"
                  x-show={`showed === 'project${index}'`}
                  x-transition:enter="transition duration-300"
                  x-transition:enter-start="opacity-0 transform translate-y-4"
                  x-transition:enter-end="opacity-100 transform translate-y-0"
                  x-transition:leave="transition duration-300"
                  x-transition:leave-start="opacity-100 transform translate-y-0"
                  x-transition:leave-end="opacity-0 transform -translate-y-4"
                >
                  <span>{project.properties.client}</span>
                  <span class="hidden md:inline">
                    {project.properties.project}
                  </span>
                  <span class="hidden md:inline">
                    {project.properties.tags}
                  </span>
                  <span>{project.properties.year}</span>
                </div>
              ))}
            </div>
            {project.cover && project.cover.type === "file" && (
              <div
                class="absolute top-16"
                x-show={`showed === 'project${index}'`}
                x-transition:enter="transition duration-300"
                x-transition:enter-start="opacity-0 transform -translate-x-10"
                x-transition:enter-end="opacity-100 transform translate-x-0"
                x-transition:leave="transition duration-300"
                x-transition:leave-start="opacity-100 transform translate-x-0"
                x-transition:leave-end="opacity-0 transform translate-x-10"
              >
                <Image
                  class="max-w-1/2 mx-auto"
                  src={project.cover.file.url}
                  width={100}
                  height={100}
                  alt=""
                />
              </div>
            )}
          </div>
        ))
      }
    </div>
    <div class="flex relative w-full">
      <DesktopLogo />
      <div class="flex h-full absolute bottom-0 left-0 right-0">
        {
          projects.map((project, index) => (
            <a
              class="grow h-full"
              x-on:mouseenter={`duplex = false; about = false; index = false; showed = 'project${index}';`}
              x-on:mouseleave={`showed = 'none'`}
              href={`/projects/${slugify(project.properties.project)}`}
            />
          ))
        }
      </div>
    </div>
  </div>
  <div class="md:hidden" slot="after-content">
    <MobileLogoBottom />
  </div>
</Layout>
